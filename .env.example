# Environment Variables Template
# Copy this file to .env.local and fill in your values

# Application
VITE_APP_NAME=Milan AI
VITE_APP_URL=https://www.milanai.org
VITE_APP_VERSION=1.0.0

# Form Submission
VITE_FORMSPREE_ENDPOINT=https://formspree.io/f/mnnpgvjp

# Analytics
VITE_GA_TRACKING_ID=G-WK3B5CBKNK

# API Configuration
VITE_API_BASE_URL=https://api.milanai.org
VITE_API_TIMEOUT=10000

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_ERROR_REPORTING=true
VITE_ENABLE_PWA=true

# Development
VITE_DEBUG_MODE=false